{
  "effortLevel": "normal",
  "skipAutoPermissionPrompt": true,
  "permissions": {
    "allow": [
      "Bash(awk:*)",
      "Bash(base64:*)",
      "Bash(basename:*)",
      "Bash(brew:*)",
      "Bash(bundle:*)",
      "Bash(cat:*)",
      "Bash(cd:*)",
      "Bash(chmod:*)",
      "Bash(clasp:*)",
      "Bash(cp:*)",
      "Bash(curl:*)",
      "Bash(cut:*)",
      "Bash(date:*)",
      "Bash(diff:*)",
      "Bash(dirname:*)",
      "Bash(echo:*)",
      "Bash(env:*)",
      "Bash(export:*)",
      "Bash(file:*)",
      "Bash(find:*)",
      "Bash(for:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(jq:*)",
      "Bash(ln:*)",
      "Bash(ls:*)",
      "Bash(make:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(nvm:*)",
      "Bash(open:*)",
      "Bash(osascript:*)",
      "Bash(pbcopy:*)",
      "Bash(pbpaste:*)",
      "Bash(pip3:*)",
      "Bash(pip:*)",
      "Bash(pnpm:*)",
      "Bash(printf:*)",
      "Bash(python3:*)",
      "Bash(python:*)",
      "Bash(rbenv:*)",
      "Bash(readlink:*)",
      "Bash(realpath:*)",
      "Bash(ruby:*)",
      "Bash(sed:*)",
      "Bash(shopify:*)",
      "Bash(sleep:*)",
      "Bash(sort:*)",
      "Bash(source:*)",
      "Bash(stat:*)",
      "Bash(tail:*)",
      "Bash(tee:*)",
      "Bash(test:*)",
      "Bash(touch:*)",
      "Bash(tr:*)",
      "Bash(uname:*)",
      "Bash(uniq:*)",
      "Bash(unzip:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(while:*)",
      "Bash(whoami:*)",
      "Bash(xargs:*)",
      "Bash(yarn:*)",
      "Bash([:*)",
      "Bash($(:*)",
      "Bash(zip:*)",
      "Bash(if:*)",
      "Bash(case:*)",
      "Bash(true:*)",
      "Bash(false:*)",
      "Bash(pwd:*)",
      "Bash(read:*)",
      "Bash(type:*)",
      "Bash(command:*)",
      "Bash(kill:*)",
      "Bash(wait:*)",
      "Bash(trap:*)",
      "Bash((:*)",
      "Bash({:*)",
      "mcp__claude_ai_Gmail__gmail_create_draft",
      "mcp__claude_ai_Gmail__gmail_get_profile",
      "mcp__claude_ai_Gmail__gmail_list_drafts",
      "mcp__claude_ai_Gmail__gmail_list_labels",
      "mcp__claude_ai_Gmail__gmail_read_message",
      "mcp__claude_ai_Gmail__gmail_read_thread",
      "mcp__claude_ai_Gmail__gmail_search_messages",
      "mcp__claude_ai_Google_Calendar__gcal_create_event",
      "mcp__claude_ai_Google_Calendar__gcal_delete_event",
      "mcp__claude_ai_Google_Calendar__gcal_find_meeting_times",
      "mcp__claude_ai_Google_Calendar__gcal_find_my_free_time",
      "mcp__claude_ai_Google_Calendar__gcal_get_event",
      "mcp__claude_ai_Google_Calendar__gcal_list_calendars",
      "mcp__claude_ai_Google_Calendar__gcal_list_events",
      "mcp__claude_ai_Google_Calendar__gcal_respond_to_event",
      "mcp__claude_ai_Google_Calendar__gcal_update_event"
    ],
    "defaultMode": "auto",
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf .)",
      "Bash(rm -rf *)",
      "Bash(git push --force)",
      "Bash(git push -f)",
      "Bash(git reset --hard:*)",
      "Bash(sudo rm:*)",
      "Bash(sudo chmod:*)",
      "Bash(> /dev/sda:*)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/pull-dotfiles.sh"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/permission-notify.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/notification-notify.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/check-stale-refs.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/recovery-detect.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/stale-branch-check.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/shopify-session-start.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/ecforce-session-start.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/load-learnings.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/block-rm.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/block-compound-commands.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/pre-push-validate.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/post-liquid-validate.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/post-liquid-validate.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/post-push-notify.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/save-learnings.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/session-end-notify.sh"
          }
        ]
      }
    ]
  }
}
