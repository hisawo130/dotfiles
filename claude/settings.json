  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/pull-dotfiles.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/effort-calibrate.sh"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_name // \"unknown\"' | { read -r t; curl -s -H 'Title: 承認待ち' -H 'Priority: high' -H 'Tags: rotating_light' -d \"$t の実行に承認が必要です\" ntfy.sh/claude-2e88e2160d55; } 2>/dev/null || true"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude Codeが入力待ちです\" with title \"Claude Code\" sound name \"Ping\"' 2>/dev/null; curl -s -H 'Title: Claude Code' -H 'Tags: bell' -d '入力待ちです' ntfy.sh/claude-2e88e2160d55 2>/dev/null || true"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "_stale=$(find \"$HOME/dotfiles/claude/references\" -name '*.md' -mtime +14 2>/dev/null | while read -r f; do echo \"$(basename \"$f\"): $(stat -f '%Sm' -t '%Y-%m-%d' \"$f\")\"; done); [ -n \"$_stale\" ] && jq -n --arg s \"$_stale\" '{\"systemMessage\":(\"⚠️ 以下のリファレンスが14日以上未更新:\\n\" + $s)}' || true"
          },
          {
            "type": "command",
            "command": "_sf=\"$HOME/.claude/projects/$(echo \"$PWD\" | sed 's|/|-|g')/state.md\"; [ -f \"$_sf\" ] && [ -s \"$_sf\" ] && [ \"$(wc -c < \"$_sf\" | tr -d ' ')\" -le 2048 ] && jq -n --rawfile s \"$_sf\" '{\"systemMessage\": (\"📋 Project state loaded:\\n\" + $s)}' || true"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/recovery-detect.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/shopify-session-start.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/ecforce-session-start.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/stale-branch-check.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/block-rm.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/post-liquid-validate.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/post-liquid-validate.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/post-push-notify.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/session-end-notify.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/save-learnings.sh",
            "timeout": 90,
            "statusMessage": "学びを抽出中...",
            "async": true
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/ai-capture.sh",
            "timeout": 120,
            "statusMessage": "AIで学びを抽出中...",
            "async": true
          },
          {
            "type": "command",
            "command": "mkdir -p \"$HOME/.claude/projects/$(echo \"$PWD\" | sed 's|/|-|g')\" && touch \"$HOME/.claude/projects/$(echo \"$PWD\" | sed 's|/|-|g')/.session-clean\"",
            "async": true
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "_dirty=$(git -C \"$PWD\" status --porcelain 2>/dev/null | grep -v '^?'); [ -n \"$_dirty\" ] && jq -n --arg d \"$_dirty\" '{\"systemMessage\": (\"⚠️ コンパクト前に未コミットの変更があります。コンパクト後に履歴が失われる前にコミットしてください:\\n\" + $d)}' || true"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "_sf=\"$HOME/.claude/projects/$(echo \"$PWD\" | sed 's|/|-|g')/state.md\"; [ -f \"$_sf\" ] && [ -s \"$_sf\" ] && [ \"$(wc -c < \"$_sf\" | tr -d ' ')\" -le 2048 ] && jq -n --rawfile s \"$_sf\" '{\"systemMessage\": (\"📋 コンパクト後 — プロジェクト状態を再注入:\\n\" + $s)}' || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.py"
  },
  "enabledPlugins": {
    "superpowers@superpowers-dev": true
  },
  "extraKnownMarketplaces": {
    "superpowers-dev": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers"
      }
    }
  },
  "effortLevel": "low",
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true,
  "autoMode": {
    "allow": [
      "File read/write/delete operations within the home directory or project directories",
      "Git operations including add, commit, push, pull, branch, merge, rebase",
      "Package management with npm, yarn, pnpm, bun, pip, brew, gem, composer",
      "Running build, test, lint, and format commands",
      "Creating, renaming, or deleting files and directories (non-recursive rm)",
      "Shopify CLI and theme operations",
      "Shell script execution for automation tasks",
      "Reading and writing dotfiles under ~/.claude or ~/dotfiles",
      "GitHub CLI (gh) operations for PRs, issues, and repo management",
      "Web fetching and searching for research tasks"
    ],
    "environment": [
      "User is a web/frontend developer working with Shopify and ecforce platforms",
      "All git operations are reversible; non-destructive actions should proceed without confirmation",
      "Timezone is JST; user operates autonomously and prefers uninterrupted execution"
    ]
  },
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--headless"
      ]
    }
  }
}
